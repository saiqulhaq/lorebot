# --- Slack (required) ---
# Bot token (xoxb-...) from OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-token
# App-level token (xapp-...) with connections:write, from Basic Information > App-Level Tokens
SLACK_APP_TOKEN=xapp-your-token

# --- Knowledge base (one of the two required) ---
# Git URL to clone the knowledge base from (cloned into $DATA_DIR/kb)
KB_REPO_URL=git@github.com:your-org/knowledge-base.git
# ...or point at an existing local clone instead
#KB_DIR=/path/to/existing/kb

# --- OpenCode server ---
# Base URL of a running OpenCode v2 server (start one with: opencode serve)
OPENCODE_URL=http://localhost:4096
# Set if the server was started with OPENCODE_SERVER_PASSWORD
#OPENCODE_SERVER_PASSWORD=

# --- Optional tuning ---
# Agent name passed to session.create (installed automatically by default)
#OPENCODE_AGENT=kb
# git pull interval in seconds; 0 disables background sync
#KB_SYNC_INTERVAL_SECONDS=300
# Set to false if you manage .opencode/agents/kb.md in the KB repo yourself
#KB_MANAGE_AGENT=true
# Base URL to linkify cited file paths, e.g. https://github.com/your-org/kb/blob/main/
#KB_LINK_BASE=
# Abort waiting for an answer after this many seconds
#ANSWER_TIMEOUT_SECONDS=300
# --- Graphify sync (optional second role; see docs/docs/sync.mdx) ---
# GitHub App with Contents:write, installed on the app repos to sync
#GITHUB_APP_ID=
#GITHUB_APP_INSTALLATION_ID=
#GITHUB_APP_PRIVATE_KEY_FILE=/path/to/github-app.pem
# LLM credentials for graph builds (graphify extracts entities with an LLM)
#LITELLM_SERVICE_ACCOUNT_KEY=
#LITELLM_BASE_URL=https://litellm.hhstaging.dev/v1
# Path to the graphify binary if not on PATH
#GRAPHIFY_BIN=graphify

# Where the sqlite db and default KB clone live
#DATA_DIR=./data
# debug | info | warn | error
#LOG_LEVEL=info
# pretty (human-readable) | json (one object per line, for log pipelines)
#LOG_FORMAT=pretty
